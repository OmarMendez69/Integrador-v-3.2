      </HBox>

      <!-- CONTENIDO -->
      <TextArea fx:id="txtContenido" editable="false" wrapText="true" layoutX="16.0" layoutY="62.0" prefHeight="300.0" prefWidth="448.0" style="-fx-font-family: 'Consolas', 'Courier New', monospace; -fx-font-size: 12px; -fx-background-color: #F9FAFB; -fx-border-color: #E5E7EB; -fx-border-radius: 6; -fx-background-radius: 6;" />

