      <!-- HEADER -->
      <HBox alignment="CENTER_LEFT" layoutX="0.0" layoutY="0.0" prefHeight="50.0" prefWidth="480.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #b721ff 0%, #21d4fd 100%); -fx-padding: 0 16 0 16;">
         <ImageView fitHeight="28.0" pickOnBounds="true" preserveRatio="true">
            <image><Image url="@../images/Logo.png" /></image>
         </ImageView>
