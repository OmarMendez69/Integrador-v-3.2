<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="560.0" prefWidth="680.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #b721ff 0%, #21d4fd 100%);" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="utng.gtid2.jome.PrestamoController">
   <children>
      <Pane layoutX="60.0" layoutY="40.0" prefHeight="480.0" prefWidth="560.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 12, 0, 0, 4);">
         <children>

            <!-- ===== Encabezado ===== -->
            <ImageView fitHeight="34.0" layoutX="40.0" layoutY="24.0" pickOnBounds="true" preserveRatio="true">
               <image><Image url="@../images/Logo.png" /></image>
            </ImageView>
            <Label layoutX="82.0" layoutY="22.0" text="CGTI">
               <font><Font name="System Bold" size="22.0" /></font>
            </Label>
            <Label layoutX="82.0" layoutY="50.0" text="Registro de Préstamo" textFill="#00afff">
               <font><Font name="System Bold" size="13.0" /></font>
            </Label>

            <Separator layoutX="40.0" layoutY="72.0" prefWidth="480.0" />

            <!-- ===== Fila 1: Folio + Fechas ===== -->
            <Label layoutX="40.0" layoutY="92.0" text="Folio Préstamo">
               <font><Font name="System Bold" size="10.0" /></font>
            </Label>
            <TextField fx:id="txtFolio" layoutX="40.0" layoutY="108.0" prefHeight="30.0" prefWidth="180.0" editable="false" focusTraversable="false" text="Se calcula automáticamente" style="-fx-background-radius: 6; -fx-border-color: #d9dee3; -fx-border-radius: 6; -fx-background-color: #f0f2f5; -fx-text-fill: #8a8f98;" />

            <Label layoutX="240.0" layoutY="92.0" text="Fecha de Préstamo">
               <font><Font name="System Bold" size="10.0" /></font>
            </Label>
            <TextField fx:id="txtFechaPrestamo" layoutX="240.0" layoutY="108.0" prefHeight="30.0" prefWidth="140.0" promptText="dd/mm/aaaa" style="-fx-background-radius: 6; -fx-border-color: #d9dee3; -fx-border-radius: 6;" />

            <Label layoutX="400.0" layoutY="92.0" text="Fecha Devolución">
               <font><Font name="System Bold" size="10.0" /></font>
            </Label>
            <TextField fx:id="txtFechaDevolucion" layoutX="400.0" layoutY="108.0" prefHeight="30.0" prefWidth="120.0" promptText="dd/mm/aaaa" style="-fx-background-radius: 6; -fx-border-color: #d9dee3; -fx-border-radius: 6;" />

            <!-- ===== Fila 2: Insumo + Responsable ===== -->
            <Label layoutX="40.0" layoutY="156.0" text="Insumo Prestado">
               <font><Font name="System Bold" size="10.0" /></font>
            </Label>
            <ComboBox fx:id="cmbInsumo" layoutX="40.0" layoutY="172.0" prefHeight="30.0" prefWidth="240.0" promptText="Selecciona un insumo" style="-fx-background-radius: 6; -fx-border-color: #d9dee3; -fx-border-radius: 6;" />

            <Label layoutX="300.0" layoutY="156.0" text="Responsable / Técnico">
               <font><Font name="System Bold" size="10.0" /></font>
            </Label>
            <ComboBox fx:id="cmbResponsable" layoutX="300.0" layoutY="172.0" prefHeight="30.0" prefWidth="220.0" promptText="Selecciona un usuario" style="-fx-background-radius: 6; -fx-border-color: #d9dee3; -fx-border-radius: 6;" />

            <!-- ===== Fila 3: Observaciones ===== -->
            <Label layoutX="40.0" layoutY="220.0" text="Observaciones">
               <font><Font name="System Bold" size="10.0" /></font>
            </Label>
            <TextField fx:id="txtObservaciones" layoutX="40.0" layoutY="236.0" prefHeight="30.0" prefWidth="480.0" promptText="Opcional" style="-fx-background-radius: 6; -fx-border-color: #d9dee3; -fx-border-radius: 6;" />

            <Separator layoutX="40.0" layoutY="284.0" prefWidth="480.0" />

            <!-- ===== Mensaje de validación ===== -->
            <Label fx:id="lblError" layoutX="40.0" layoutY="298.0" prefWidth="480.0" text="" textFill="#e53935" wrapText="true">
               <font><Font size="10.0" /></font>
            </Label>

            <!-- ===== Botones principales ===== -->
            <Button fx:id="btnGuardar" layoutX="40.0" layoutY="336.0" mnemonicParsing="false" onAction="#mostrarInformacion" prefHeight="32.0" prefWidth="150.0" style="-fx-background-color: linear-gradient(to bottom right, #4ba4ff, #26d6ff); -fx-background-radius: 6;" text="Registrar" textFill="WHITE">
               <font><Font name="System Bold" size="12.0" /></font>
            </Button>
            <Button fx:id="btnCancelar" layoutX="200.0" layoutY="336.0" mnemonicParsing="false" onAction="#accionCancelar" prefHeight="32.0" prefWidth="150.0" style="-fx-background-color: #e53935; -fx-background-radius: 6;" text="Cancelar" textFill="WHITE">
               <font><Font name="System Bold" size="12.0" /></font>
            </Button>
            <Button fx:id="btnVolver" layoutX="360.0" layoutY="336.0" mnemonicParsing="false" onAction="#accionVolver" prefHeight="32.0" prefWidth="160.0" style="-fx-background-color: linear-gradient(to bottom right, #4ba4ff, #26d6ff); -fx-background-radius: 6;" text="Volver al panel" textFill="WHITE">
               <font><Font name="System Bold" size="12.0" /></font>
            </Button>

            <!-- ===== Acceso a la lista de préstamos ===== -->
            <Button fx:id="btnVerHistorial" layoutX="40.0" layoutY="386.0" mnemonicParsing="false" onAction="#accionVerHistorial" prefHeight="34.0" prefWidth="480.0" style="-fx-background-color: linear-gradient(to bottom right, #b721ff, #21d4fd); -fx-background-radius: 6;" text="Ver Lista de Préstamos" textFill="WHITE">
               <font><Font name="System Bold" size="12.0" /></font>
            </Button>

         </children>
      </Pane>
   </children>
</AnchorPane>